# Copy to `.env` and adjust. Never commit `.env` (see `.gitignore`).
#
# --- Django core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Production: set DEBUG=False, USE_TLS=True, and use real hosts/origins.
USE_TLS=False
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Comma-separated. Include scheme (https in production).
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database ---
# SQLite (local default): use DB_ENGINE below; do not set DB_NAME unless you need a
# custom path (default in settings.py is BASE_DIR/db.sqlite3).
DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# PostgreSQL (e.g. docker-compose `db` service):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=pathycode
# DB_USER=pathycode
# DB_PASSWORD=your-db-password
# DB_HOST=db
# DB_PORT=5432

# --- URLs used in emails and payment redirects ---
FRONTEND_URL=http://localhost:3000
PROJECT_BASE_URL=http://localhost:8000

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# --- PayFast (sandbox defaults; replace in production) ---
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
# Override if PROJECT_BASE_URL is not the public API base:
# PAYFAST_RETURN_URL=
# PAYFAST_CANCEL_URL=
# PAYFAST_NOTIFY_URL=
# PAYFAST_SANDBOX_URL=https://sandbox.payfast.co.za/eng/process
